#!/usr/bin/env bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
FILE="${THREEDVR_LEADS_FILE:-$ROOT/leads.csv}"
LAUNCH_URL="https://3dvr.tech/launch-in-3-days.html"
mode="${1:-a}"
target="$2"

get_lead() {
  [ -f "$FILE" ] || return 1
  awk -F, -v name="$target" 'NR>1 && $1==name {print; exit}' "$FILE"
}

msg_a() {
  cat <<'MESSAGE'
Hi,

I was looking at your site and noticed one small customer-flow detail that could make the next step clearer.

If it would be useful, I can send over the specific note. If not, no problem.

Thomas
3DVR
MESSAGE
}

msg_b() {
  cat <<'MESSAGE'
Hi,

I noticed one practical mobile/customer-flow detail on your site that may be worth tightening.

I can send the quick note if helpful. If now is not useful, no worries.

Thomas
3DVR
MESSAGE
}

msg_c() {
  cat <<'MESSAGE'
Hi,

One part of your site looked like it could be a little easier for customers to act on.

I can send the note over if you want it. If not, no problem.

Thomas
3DVR
MESSAGE
}

msg_offer() {
  cat <<MESSAGE
Hi,

I help small service businesses make their websites clearer and easier for customers to act on.

The simplest starting point is a short review, one practical fix, and a clear next step. Details are here if useful: $LAUNCH_URL

Thomas
3DVR
MESSAGE
}

msg_lead() {
  line="$(get_lead)"
  if [ -n "$line" ]; then
    name="$(printf '%s' "$line" | awk -F, '{print $1}')"
    link="$(printf '%s' "$line" | awk -F, '{print $2}')"
    cat <<MESSAGE
Hi ${name} team,

I was looking at your site (${link}) and noticed one small place where the next step for visitors could be clearer.

If it would be useful, I can send over the specific note. If not, no problem.

Thomas
3DVR
MESSAGE
  else
    msg_a
  fi
}

msg_smart() {
  line="$(get_lead)"
  if [ -z "$line" ]; then
    msg_a
    return
  fi

  name="$(printf '%s' "$line" | awk -F, '{print $1}')"
  link="$(printf '%s' "$line" | awk -F, '{print $2}')"
  contact="$(printf '%s' "$line" | awk -F, '{print $3}')"
  haystack="$(printf '%s %s %s' "$name" "$link" "$contact" | tr '[:upper:]' '[:lower:]')"

  case "$haystack" in
    *menu*|*restaurant*|*cafe*|*coffee*|*food*|*bar*|*grill*)
      hint="menu or contact-flow"
      ;;
    *shop*|*store*|*product*|*cart*|*checkout*)
      hint="browse or checkout-flow"
      ;;
    *book*|*appointment*|*schedule*|*booking*)
      hint="booking or contact-flow"
      ;;
    *law*|*legal*|*attorney*|*dental*|*clinic*|*health*|*realestate*|*mortgage*)
      hint="trust or contact-flow"
      ;;
    *)
      hint="customer-flow"
      ;;
  esac

  cat <<MESSAGE
Hi ${name} team,

I was looking at your site (${link}) and noticed one small ${hint} detail that could make the next step clearer for visitors.

If it would be useful, I can send over the specific note. If not, no problem.

Thomas
3DVR
MESSAGE
}

case "$mode" in
  a) msg_a ;;
  b) msg_b ;;
  c) msg_c ;;
  offer) msg_offer ;;
  lead|personal) msg_lead ;;
  smart) msg_smart ;;
  *)
    echo 'Usage: ask-message [a|b|c|offer|lead|smart] "Business Name"'
    ;;
esac
