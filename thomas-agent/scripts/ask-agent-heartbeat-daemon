#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
if [ -f "$SCRIPT_DIR/lib/platform.sh" ]; then
  source "$SCRIPT_DIR/lib/platform.sh"
fi
STATE_DIR="${THREEDVR_AUTOPILOT_STATE_DIR:-$ROOT/state}"
PID_FILE="$STATE_DIR/agent-heartbeat.pid"
LOG_FILE="$STATE_DIR/agent-heartbeat.log"
TMUX_SESSION="${THREEDVR_AGENT_HEARTBEAT_TMUX_SESSION:-3dvr-heartbeat}"
INTERVAL_SECONDS="${THREEDVR_AGENT_HEARTBEAT_INTERVAL_SECONDS:-60}"

mkdir -p "$STATE_DIR"

is_running() {
  if command -v tmux >/dev/null 2>&1; then
    tmux has-session -t "$TMUX_SESSION" 2>/dev/null
    return $?
  fi
  [ -f "$PID_FILE" ] || return 1
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  [ -n "$pid" ] || return 1
  kill -0 "$pid" 2>/dev/null
}

case "${1:-}" in
  start)
    if is_running; then
      if command -v tmux >/dev/null 2>&1; then
        echo "Agent heartbeat already running in tmux session $TMUX_SESSION."
      else
        echo "Agent heartbeat already running (pid $(cat "$PID_FILE"))."
      fi
      exit 0
    fi
    if command -v tmux >/dev/null 2>&1; then
      tmux new-session -d -s "$TMUX_SESSION" "cd \"$ROOT\" && while true; do \"$SCRIPT_DIR/ask-agent-heartbeat\" >>\"$LOG_FILE\" 2>&1; sleep \$(( ${INTERVAL_SECONDS} )); done"
      echo "Started agent heartbeat in tmux session $TMUX_SESSION. Log: $LOG_FILE"
    else
      setsid node "$ROOT/node/agent-heartbeat.js" loop >>"$LOG_FILE" 2>&1 &
      echo "$!" > "$PID_FILE"
      echo "Started agent heartbeat (pid $!). Log: $LOG_FILE"
    fi
    ;;
  stop)
    if ! is_running; then
      echo "Agent heartbeat is not running."
      rm -f "$PID_FILE"
      exit 0
    fi
    if command -v tmux >/dev/null 2>&1; then
      tmux kill-session -t "$TMUX_SESSION"
      echo "Stopped agent heartbeat tmux session $TMUX_SESSION."
    else
      pid="$(cat "$PID_FILE")"
      kill "$pid"
      rm -f "$PID_FILE"
      echo "Stopped agent heartbeat (pid $pid)."
    fi
    ;;
  status)
    if is_running; then
      if command -v tmux >/dev/null 2>&1; then
        echo "Agent heartbeat running in tmux session $TMUX_SESSION."
      else
        echo "Agent heartbeat running (pid $(cat "$PID_FILE"))."
      fi
      echo "Log: $LOG_FILE"
    else
      echo "Agent heartbeat is not running."
      exit 1
    fi
    ;;
  run-now)
    exec "$SCRIPT_DIR/ask-agent-heartbeat"
    ;;
  logs)
    tail -n 40 "$LOG_FILE"
    ;;
  *)
    echo 'Usage: ask-agent-heartbeat-daemon start|stop|status|run-now|logs'
    exit 1
    ;;
esac
