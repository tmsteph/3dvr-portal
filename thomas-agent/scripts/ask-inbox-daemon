#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
STATE_DIR="${THREEDVR_AUTOPILOT_STATE_DIR:-$ROOT/state}"
PID_FILE="$STATE_DIR/inbox-daemon.pid"
LOG_FILE="$STATE_DIR/inbox-daemon.log"
TMUX_SESSION="${THREEDVR_INBOX_TMUX_SESSION:-3dvr-inbox}"
INTERVAL_MINUTES="${THREEDVR_INBOX_INTERVAL_MINUTES:-1}"

mkdir -p "$STATE_DIR"

is_running() {
  if command -v tmux >/dev/null 2>&1; then
    tmux has-session -t "$TMUX_SESSION" 2>/dev/null
    return $?
  fi
  [ -f "$PID_FILE" ] || return 1
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  [ -n "$pid" ] || return 1
  kill -0 "$pid" 2>/dev/null
}

case "${1:-}" in
  start)
    if is_running; then
      if command -v tmux >/dev/null 2>&1; then
        echo "Inbox daemon already running in tmux session $TMUX_SESSION."
      else
        echo "Inbox daemon already running (pid $(cat "$PID_FILE"))."
      fi
      exit 0
    fi
    if command -v tmux >/dev/null 2>&1; then
      tmux new-session -d -s "$TMUX_SESSION" "cd \"$ROOT\" && while true; do \"$SCRIPT_DIR/ask-inbox\" >>\"$LOG_FILE\" 2>&1; sleep \$(( ${INTERVAL_MINUTES} * 60 )); done"
      echo "Started inbox daemon in tmux session $TMUX_SESSION. Log: $LOG_FILE"
    else
      setsid node "$ROOT/node/inbox-monitor-loop.js" >>"$LOG_FILE" 2>&1 &
      echo "$!" > "$PID_FILE"
      echo "Started inbox daemon (pid $!). Log: $LOG_FILE"
    fi
    ;;
  stop)
    if ! is_running; then
      echo "Inbox daemon is not running."
      rm -f "$PID_FILE"
      exit 0
    fi
    if command -v tmux >/dev/null 2>&1; then
      tmux kill-session -t "$TMUX_SESSION"
      echo "Stopped inbox daemon tmux session $TMUX_SESSION."
    else
      pid="$(cat "$PID_FILE")"
      kill "$pid"
      rm -f "$PID_FILE"
      echo "Stopped inbox daemon (pid $pid)."
    fi
    ;;
  status)
    if is_running; then
      if command -v tmux >/dev/null 2>&1; then
        echo "Inbox daemon running in tmux session $TMUX_SESSION."
      else
        echo "Inbox daemon running (pid $(cat "$PID_FILE"))."
      fi
      echo "Log: $LOG_FILE"
    else
      echo "Inbox daemon is not running."
      exit 1
    fi
    ;;
  run-now)
    shift
    exec "$SCRIPT_DIR/ask-inbox" "$@"
    ;;
  logs)
    tail -n 40 "$LOG_FILE"
    ;;
  *)
    echo 'Usage: ask-inbox-daemon start|stop|status|run-now|logs'
    exit 1
    ;;
esac
