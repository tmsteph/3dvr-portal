#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
source "$SCRIPT_DIR/lib/platform.sh"

CONFIG_FILE="${THREEDVR_CONFIG_FILE:-${THREEDVR_HOME:-$HOME/.3dvr}/config/env}"

if [ -f "$CONFIG_FILE" ]; then
  set -a
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
  set +a
fi

cd "$ROOT"
exec node "$ROOT/node/agent-heartbeat.js" "${1:-}"
