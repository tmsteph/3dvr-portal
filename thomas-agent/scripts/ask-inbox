#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
if [ -f "$SCRIPT_DIR/lib/platform.sh" ]; then
  source "$SCRIPT_DIR/lib/platform.sh"
fi

DEFAULT_EMAIL_TOKEN_FILE="${HOME:-}/.3dvr-agent-operator-email-token"
if [ -n "$DEFAULT_EMAIL_TOKEN_FILE" ] && [ -f "$DEFAULT_EMAIL_TOKEN_FILE" ]; then
  if [ -z "${THREEDVR_AUTOPILOT_EMAIL_TOKEN_FILE:-}" ] || [ ! -f "$THREEDVR_AUTOPILOT_EMAIL_TOKEN_FILE" ]; then
    export THREEDVR_AUTOPILOT_EMAIL_TOKEN_FILE="$DEFAULT_EMAIL_TOKEN_FILE"
  fi
fi

node "$ROOT/node/inbox-monitor.js" "$@"
