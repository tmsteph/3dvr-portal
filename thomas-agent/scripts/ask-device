#!/usr/bin/env bash
set -euo pipefail

DEFAULT_ALIAS="${THREEDVR_DEV_ALIAS:-do-dev}"
DEFAULT_HOST="${THREEDVR_DEV_HOST:-167.172.193.194}"
DEFAULT_USER="${THREEDVR_DEV_USER:-root}"
DEFAULT_KEY="${THREEDVR_DEV_KEY:-id_ed25519_3dvr}"

usage() {
  cat <<'USAGE'
3dvr device

Commands:
  3dvr device bootstrap [--host HOST] [--alias do-dev] [--user root] [--key id_ed25519_3dvr]
  3dvr device approve "PUBLIC_KEY"

Run bootstrap on a new laptop/phone/tablet. It installs the local SSH alias,
prints the public key, and prints the approval command for an existing server
session. Run approve on the DigitalOcean server to authorize that public key.
USAGE
}

die() {
  echo "Error: $*" >&2
  exit 1
}

safe_name() {
  printf '%s' "$1" | sed 's/[^A-Za-z0-9._-]/_/g'
}

quote_sh() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

parse_common() {
  alias_name="$DEFAULT_ALIAS"
  host="$DEFAULT_HOST"
  server_user="$DEFAULT_USER"
  key_name="$DEFAULT_KEY"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --host) host="${2:-}"; shift 2 ;;
      --host=*) host="${1#--host=}"; shift ;;
      --alias) alias_name="${2:-}"; shift 2 ;;
      --alias=*) alias_name="${1#--alias=}"; shift ;;
      --user) server_user="${2:-}"; shift 2 ;;
      --user=*) server_user="${1#--user=}"; shift ;;
      --key) key_name="${2:-}"; shift 2 ;;
      --key=*) key_name="${1#--key=}"; shift ;;
      --help|-h) usage; exit 0 ;;
      *) die "Unknown option: $1" ;;
    esac
  done

  alias_name="$(safe_name "${alias_name:-$DEFAULT_ALIAS}")"
  key_name="$(safe_name "${key_name:-$DEFAULT_KEY}")"
  host="${host:-$DEFAULT_HOST}"
  server_user="${server_user:-$DEFAULT_USER}"
}

ensure_config_block() {
  ssh_config="$1"
  alias_name="$2"
  host="$3"
  server_user="$4"
  key_path="$5"

  mkdir -p "$(dirname "$ssh_config")"
  touch "$ssh_config"
  chmod 600 "$ssh_config"

  if grep -Eq "^[[:space:]]*Host[[:space:]]+$alias_name([[:space:]]|\$)" "$ssh_config"; then
    echo "SSH config already has Host $alias_name."
    return 0
  fi

  {
    printf '\n'
    printf 'Host %s\n' "$alias_name"
    printf '  HostName %s\n' "$host"
    printf '  User %s\n' "$server_user"
    printf '  IdentityFile %s\n' "$key_path"
    printf '  IdentitiesOnly yes\n'
  } >> "$ssh_config"
  echo "Added SSH config: Host $alias_name -> $server_user@$host"
}

bootstrap() {
  parse_common "$@"
  ssh_dir="$HOME/.ssh"
  key_path="$ssh_dir/$key_name"
  public_key_path="$key_path.pub"
  ssh_config="$ssh_dir/config"

  mkdir -p "$ssh_dir"
  chmod 700 "$ssh_dir"

  if [ ! -f "$key_path" ]; then
    ssh-keygen -t ed25519 -f "$key_path" -C "$(hostname)-3dvr" -N ""
  else
    echo "Using existing SSH key: $key_path"
  fi
  chmod 600 "$key_path"
  chmod 644 "$public_key_path" 2>/dev/null || true

  ensure_config_block "$ssh_config" "$alias_name" "$host" "$server_user" "$key_path"

  public_key="$(cat "$public_key_path")"
  quoted_public_key="$(quote_sh "$public_key")"

  cat <<EOF

This device is prepared.

Public key:
$public_key

From any device that already connects to the server, run:
ssh $alias_name $(quote_sh "3dvr device approve $quoted_public_key || 3dvr-onboard-device $quoted_public_key")

Then test on this device:
ssh $alias_name
EOF
}

approve() {
  public_key="${1:-}"
  if [ -z "$public_key" ] && [ ! -t 0 ]; then
    public_key="$(cat)"
  fi
  public_key="$(printf '%s' "$public_key" | tr -d '\r' | sed -n '1p')"
  case "$public_key" in
    ssh-rsa\ *|ssh-ed25519\ *|ecdsa-sha2-*\ *) ;;
    *) die "Paste one SSH public key line beginning with ssh-ed25519, ssh-rsa, or ecdsa-sha2-." ;;
  esac

  auth_keys="$HOME/.ssh/authorized_keys"
  mkdir -p "$HOME/.ssh"
  chmod 700 "$HOME/.ssh"
  touch "$auth_keys"
  chmod 600 "$auth_keys"

  if grep -qxF "$public_key" "$auth_keys"; then
    echo "Key already authorized."
  else
    printf '%s\n' "$public_key" >> "$auth_keys"
    echo "Authorized new device key."
  fi
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  bootstrap|connect|setup) bootstrap "$@" ;;
  approve|authorize) approve "$@" ;;
  help|-h|--help) usage ;;
  *) usage; exit 1 ;;
esac
