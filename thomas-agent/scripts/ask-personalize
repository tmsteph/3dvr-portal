#!/usr/bin/env bash
name="$1"
site="$2"
contact="$3"

hint="site"

case "$site $contact" in
  *menu*|*Menu*) hint="menu or contact flow" ;;
  *book*|*reserv*|*order*) hint="booking or ordering flow" ;;
  *contact*|*about*) hint="contact flow" ;;
  *event*|*cater*) hint="events or catering flow" ;;
esac

cat <<MESSAGE
Hi $name team,

I was looking at your site and noticed one small $hint detail that could make the next step clearer for visitors.

If it would be useful, I can send over the specific note. If not, no problem.

Thomas
3DVR
MESSAGE
