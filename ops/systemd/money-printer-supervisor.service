[Unit]
Description=3DVR Money Printer supervised operator cycle
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/projects/3dvr-portal
EnvironmentFile=-%h/.config/3dvr/money-printer.env
ExecStart=/usr/bin/npm run money-printer:supervisor -- --ai
Nice=5

[Install]
WantedBy=default.target
