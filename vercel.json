{
  "crons": [
    {
      "path": "/api/growth/homepage-hero-cron",
      "schedule": "43 2 * * *"
    },
    {
      "path": "/api/money/autopilot-cron",
      "schedule": "17 1 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(css|js|png|jpg|jpeg|gif|svg|webp|woff2?)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/app-manifests/(.*)\\.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/calendar.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/calendar/calendar.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/calendar/pwa-install.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/contacts/contacts.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/pwa-install.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/contacts/pwa-install.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/contacts/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/contacts/"
        }
      ]
    },
    {
      "source": "/calendar/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/calendar/"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/:calendarPath((?!api(?:/|$)|_vercel(?:/|$)|styles/|icons/|favicon\\.ico$|gun-init\\.js$|oauth\\.js$|calendar(?:/|$)).*)",
      "has": [
        {
          "type": "host",
          "value": "calendar.3dvr.tech"
        }
      ],
      "destination": "/calendar/:calendarPath*"
    },
    {
      "source": "/:calendarPath((?!api(?:/|$)|_vercel(?:/|$)|styles/|icons/|favicon\\.ico$|gun-init\\.js$|oauth\\.js$|calendar(?:/|$)).*)",
      "has": [
        {
          "type": "host",
          "value": "calendar-staging.3dvr.tech"
        }
      ],
      "destination": "/calendar/:calendarPath*"
    },
    {
      "source": "/webhooks/stripe",
      "destination": "/api/webhooks/stripe"
    },
    {
      "source": "/api/account-recovery-email",
      "destination": "/api/calendar/reminder-email"
    },
    {
      "source": "/api/vercel-deploy",
      "destination": "/api/github-publish?provider=vercel"
    },
    {
      "source": "/video",
      "destination": "/portal.3dvr.tech/video/index.html"
    },
    {
      "source": "/video/",
      "destination": "/portal.3dvr.tech/video/index.html"
    },
    {
      "source": "/video/index.html",
      "destination": "/portal.3dvr.tech/video/index.html"
    }
  ]
}
